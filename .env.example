# Application Environment
NODE_ENV=development

# Server Configuration
# Use 5000 by default. If the port is busy in development, the server can try PORT+1.
PORT=5000
PORT_FALLBACK=true

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?appName=<app>
# MONGO_URI is also supported for local setups that already use that name.

# Authentication
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d

# Cloudinary Configuration (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Google Login / Signup
# Use the same OAuth Web Client ID as VITE_GOOGLE_CLIENT_ID in the frontend.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id

# CORS Origins (comma-separated list)
# Add your frontend URLs here
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,https://akshar-real-estate.vercel.app


GOOGLE_CLIENT_ID=984057796246-7qftconhhkke82bu2f6clovd9cbpvci1.apps.googleusercontent.com